{
  "name": "chatgpt-pkm",
  "productName": "ChatGPT PKM 2.0",
  "private": true,
  "version": "2.0.0",
  "description": "Sistema de gerenciamento pessoal de conhecimento para ChatGPT",
  "author": "Your Name",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "bun scripts/dev.js",
    "vite": "vite",
    "electron": "electron",
    "build": "vite build",
    "preview": "vite preview",
    "electron:build": "vite build && electron-builder",
    "electron:build:win": "vite build && electron-builder --win --x64",
    "electron:build:portable": "vite build && electron-builder --win portable"
  },
  "devDependencies": {
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "autoprefixer": "^10.4.16",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.31",
    "svelte": "^4.2.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.3.5",
    "vite": "^5.0.0",
    "wait-on": "^9.0.3"
  },
  "dependencies": {
    "dexie": "^4.2.1",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.27",
    "marked": "^11.1.0",
    "marked-highlight": "^2.2.3",
    "marked-katex-extension": "^5.1.6",
    "tailwind": "^4.0.0"
  },
  "build": {
    "appId": "com.chatgpt-pkm.app",
    "productName": "ChatGPT PKM 2.0",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ChatGPT PKM 2.0"
    },
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [],
    "asar": true,
    "compression": "maximum"
  }
}